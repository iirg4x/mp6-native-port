+  for (uint32_t mip = 1; mip < ref.mipCount; ++mip) {
+    const wgpu::TextureViewDescriptor srcViewDescriptor{
+        .label = "MipGen src view",
+        .format = ref.format,
+        .dimension = wgpu::TextureViewDimension::e2D,
+        .baseMipLevel = mip - 1,
+        .mipLevelCount = 1,
+    };
+    const auto srcView = ref.texture.CreateView(&srcViewDescriptor);
+    const wgpu::TextureViewDescriptor dstViewDescriptor{
+        .label = "MipGen dst view",
+        .format = ref.format,
+        .dimension = wgpu::TextureViewDimension::e2D,
+        .baseMipLevel = mip,
+        .mipLevelCount = 1,
+    };
+    const auto dstView = ref.texture.CreateView(&dstViewDescriptor);
+
+    const std::array bindGroupEntries{
+        wgpu::BindGroupEntry{
+            .binding = 0,
+            .sampler = g_linearSampler,
+        },
+        wgpu::BindGroupEntry{
+            .binding = 1,
+            .textureView = srcView,
+        },
+    };
+    const wgpu::BindGroupDescriptor bindGroupDescriptor{
+        .layout = g_mipBindGroupLayout,
+        .entryCount = bindGroupEntries.size(),
+        .entries = bindGroupEntries.data(),
+    };
+    const auto bindGroup = g_device.CreateBindGroup(&bindGroupDescriptor);
+
+    const std::array colorAttachments{
+        wgpu::RenderPassColorAttachment{
+            .view = dstView,
+            .loadOp = wgpu::LoadOp::Clear,
+            .storeOp = wgpu::StoreOp::Store,
+            .clearValue = {0.0, 0.0, 0.0, 0.0},
+        },
+    };
+    const wgpu::RenderPassDescriptor renderPassDescriptor{
+        .label = "TexCopyConv MipGen Pass",
+        .colorAttachmentCount = colorAttachments.size(),
+        .colorAttachments = colorAttachments.data(),
+    };
+    const auto pass = cmd.BeginRenderPass(&renderPassDescriptor);
+    pass.SetPipeline(pipeline);
+    pass.SetBindGroup(0, bindGroup);
+    pass.Draw(3);
+    pass.End();
