 static std::atomic_bool g_initialized = false;
+// Anti-Aliasing P3 (aurora-patches/0018): SSAA supersampling. g_ssaaFactor
+// (read from AuroraConfig.ssaa at init) scales the content framebuffer while
+// the surface stays native; the existing present-resample pass downsamples.
+// 1.0 = off (byte-identical). g_maxTextureDimension2D caches the adapter limit
+// so the scaled size is clamped and never exceeds what the device allows.
+static float g_ssaaFactor = 1.f;
+static uint32_t g_maxTextureDimension2D = 0;
 
 namespace {
 
@@ -328,6 +335,25 @@ uint32_t viewport_extent(float value) noexcept {
   return std::max(1u, static_cast<uint32_t>(std::lround(std::max(value, 1.f))));
 }
 
+#ifndef __ANDROID__
+// Anti-Aliasing P3 (aurora-patches/0018): scale a content-framebuffer extent by
+// the SSAA factor, clamped to the device's max 2D texture dimension so an
+// aggressive factor on a high-res window can never request a texture the device
+// rejects. Factor <= 1 returns the extent unchanged (exact native -> the SSAA-
+// off path is byte-identical). Desktop-only (compiled out under __ANDROID__).
+uint32_t apply_ssaa_scale(uint32_t dim) noexcept {
+  if (g_ssaaFactor <= 1.f || dim == 0) {
+    return dim;
+  }
+  auto scaled = static_cast<uint32_t>(
+      std::max<double>(1.0, std::lround(static_cast<double>(dim) * static_cast<double>(g_ssaaFactor))));
+  if (g_maxTextureDimension2D != 0 && scaled > g_maxTextureDimension2D) {
+    scaled = g_maxTextureDimension2D;
+  }
+  return scaled;
+}
+#endif
+
 } // namespace
 
