<?xml version="1.0" encoding="utf-8"?>
<!-- MP6 native port : U-A2 (docs/UA2_ANDROID_GRAPHICS.md). Minimal on
     purpose: no permissions at all (the disc tree lives in the app's OWN
     external files dir, which needs none), landscape-locked, single
     instance. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    android:installLocation="auto">

    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />
    <uses-feature android:name="android.hardware.gamepad" android:required="false" />
    <uses-feature android:name="android.hardware.usb.host" android:required="false" />

    <!-- Install-time-normal permission, REQUIRED: the game's PAD init stops
         rumble (PADControlMotor) -> aurora::pad -> SDL rumble -> Java
         VibratorService, which throws SecurityException without this, and
         SDL's JNI call turns that into a fatal JNI abort (measured on
         device, docs/UA2_ANDROID_GRAPHICS.md). -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- U-A3 (docs/UA3_DEVICE_PARITY.md) back-button policy: OPT OUT of
         predictive back. Android 16 enables the OnBackInvokedCallback path
         by default for targetSdk 36 apps, which bypasses Activity
         .onBackPressed() entirely and lets the SYSTEM finish() the activity
         on BACK (measured on-device as an instant app kill, ActivityRecord
         "f}" with no app code involved), exactly the "instant kill
         mid-save-write" hazard this policy exists to prevent. With the
         legacy behavior restored, BACK arrives as a normal KEYCODE_BACK key
         event, SDL's glue consumes it into SDL_SCANCODE_AC_BACK, and
         aurora_bridge.c's Android keybind maps it onto PAD B (menu
         cancel/back); main_native.c additionally arms
         SDL_ANDROID_TRAP_BACK_BUTTON so the onBackPressed() fallback can
         never finish() either. Exit = HOME/recents, like any fullscreen
         game. -->
    <application
        android:allowBackup="false"
        android:enableOnBackInvokedCallback="false"
        android:hardwareAccelerated="true"
        android:appCategory="game"
        android:isGame="true"
        android:label="MP6 Native"
        android:theme="@android:style/Theme.NoTitleBar.Fullscreen">

        <activity
            android:name="com.mp6.game.Mp6Activity"
            android:alwaysRetainTaskState="true"
            android:configChanges="layoutDirection|locale|orientation|uiMode|screenLayout|screenSize|smallestScreenSize|keyboard|keyboardHidden|navigation"
            android:exported="true"
            android:label="MP6 Native"
            android:launchMode="singleInstance"
            android:screenOrientation="landscape"
            android:preferMinimalPostProcessing="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
