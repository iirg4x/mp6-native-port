--- a/src/game/armem.c
+++ b/src/game/armem.c
@@ -2,0 +3 @@
+#include "be.h"
@@ -327 +328 @@
-    s32 *dirBuf;
+    s32 *dirBuf; s32 nextOff; s32 rawLen; s32 decodeType;
@@ -348 +349,15 @@
-    count = dirBuf[0];
+    /* preLoadBuf is DMA'd straight from ARAM -- itself a raw copy of the
+     * original big-endian disc bytes -- so dirBuf[0]/dirBuf[1] here are
+     * two consecutive BE u32 offsets into this ARAM-cached directory's
+     * blob, the exact same per-file offset-table shape game/data.c's
+     * GetFileInfo already reads via be32(), not native ints. Confirmed a
+     * real bug, not a guess: an unfixed read here fed a bogus, huge size
+     * into HuMemDirectMallocNum a few lines down, printing a genuine
+     * "HuMem>memory alloc error" and -- via HuWinFrameCreate's own
+     * missing NULL check one level up (game/window.c) -- crashing
+     * OpeningExec's window-frame setup the first time this port ever
+     * reached that far. */
+    count = (s32)be32(&dirBuf[0]);
@@ -350 +365,2 @@
-    if(dirBuf[1] - count < 0) {
+    nextOff = (s32)be32(&dirBuf[1]);
+    if(nextOff - count < 0) {
@@ -353 +369 @@
-        size = (dirBuf[1] - count + 0x3F) & 0xFFFFFFFE0;
+        size = (nextOff - count + 0x3F) & 0xFFFFFFFE0;
@@ -367 +383,9 @@
-    dst = HuMemDirectMallocNum(heap, (dirBuf[0] + 1) & ~1, num);
+    /* Same container-header shape game/data.c's GetFileInfo and
+     * src/REL/bootDll/boot.c's NintendoDataDecode/WarningDataDecode
+     * (both already patched) fix elsewhere: a BE u32 rawLen then a BE
+     * u32 decodeType immediately before the actual payload bytes
+     * HuDecodeData consumes (those payload bytes themselves are never
+     * byte-swapped -- decode.c/sprman.c's own concern, not this one). */
+    rawLen = (s32)be32(&dirBuf[0]);
+    decodeType = (s32)be32(&dirBuf[1]);
+    dst = HuMemDirectMallocNum(heap, (rawLen + 1) & ~1, num);
@@ -371 +395 @@
-    HuDecodeData(&dirBuf[2], dst, dirBuf[0], dirBuf[1]);
+    HuDecodeData(&dirBuf[2], dst, rawLen, decodeType);
