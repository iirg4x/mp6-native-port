+ * save_endian.c instead (see shim/include/mp6_save_endian.h for the whole
+ * design). Load side converts AFTER the box bytes are located (buffer
+ * stays BE); save side composes the BE image directly into the buffer
+ * (the card image never holds a native-endian word). */
+#include "mp6_save_endian.h"
