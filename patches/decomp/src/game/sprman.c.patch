+ * NOTE, recorded honestly: this check alone measured as a no-op in-game
+ * for the exact Bonus Star repro (rebuilt, re-ran, byte-identical output)
+ * -- because this game ships many same-sized, same-shape single-image
+ * ANIM icons (every simple confirm-screen badge shares byte-identical
+ * bankNum/patNum/bmpNum/bankOff/patOff), a stale entry from any OTHER
+ * same-shaped icon fingerprints identically to the correct one. Kept as a
+ * second, narrower defense (it does catch a collision against a
+ * DIFFERENTLY shaped stale object); the real fix is
+ * mp6_animCacheClear(), below, called from the one place that actually
+ * performs this class of bulk reclaim (docs/B2_BONUS_SPRITE.md section 5
+ * has the full writeup of why this check alone wasn't sufficient). */
+static u32 mp6_animFingerprint(const void *p)
+{
+    const u8 *b = (const u8 *)p;
+    u32 h = 2166136261u;
+    s32 k;
+    for(k = 0; k < 6; k++) {
+        h = (h ^ b[k]) * 16777619u;
+    }
+    for(k = 8; k < 16; k++) {
+        h = (h ^ b[k]) * 16777619u;
+    }
+    return h;
+}
+
+static ANIMDATA *mp6_animCacheFind(void *data)
+{
+    s16 i;
+    for(i=0; i<MP6_ANIM_CACHE_MAX; i++) {
+        if(mp6_animCache[i].rawData == data) {
+            if(mp6_animCache[i].fingerprint == mp6_animFingerprint(data)) {
+                return mp6_animCache[i].anim;
+            }
+            /* Stale: this address no longer holds what was cached (see the
+             * B2 comment above). Drop it and keep looking -- a duplicate,
+             * still-valid entry could exist further along -- rather than
+             * trusting it or giving up early. */
+            mp6_animCache[i].rawData = NULL;
+            mp6_animCache[i].anim = NULL;
+        }
+    }
+    return NULL;
+}
+
+static void mp6_animCacheAdd(void *data, ANIMDATA *anim)
+{
+    s16 i;
+    for(i=0; i<MP6_ANIM_CACHE_MAX; i++) {
+        if(mp6_animCache[i].rawData == NULL) {
+            mp6_animCache[i].rawData = data;
+            mp6_animCache[i].anim = anim;
+            mp6_animCache[i].fingerprint = mp6_animFingerprint(data);
+            return;
+        }
+    }
+    /* Table full: harmless to drop -- a repeat HuSprAnimRead(data) call
+     * just re-parses into its own independent (still correct) copy
+     * instead of sharing/refcounting one. */
+}
+
+/* MP6 native port -- M3 (docs/M3_HSF.md). Real root-cause fix: this table
+ * has no expiry, but the ANIMDATA objects it references DO get freed
+ * (HuSprAnimKill, below, once useNum drops to 0) -- called from here right
+ * before the real HuMemDirectFree(anim), so no stale entry can ever
+ * outlive the memory it points at. Purges EVERY slot whose key OR value
+ * matches `anim`: a self-registered entry (this file's own
+ * HuSprAnimRead/HuSprAnimMake fixes, above) has rawData==anim==this exact
+ * pointer; an original raw-packed-data-keyed entry has anim==this pointer
+ * but a DIFFERENT rawData key (the still-packed source blob) -- both need
+ * to go, since either one, left stale, lets a future allocation that
+ * happens to reuse this exact freed address get a false-positive cache
+ * hit against semantically unrelated (or simply no-longer-valid) data.
+ * A linear scan over a few thousand slots costs nothing measurable at
+ * this call frequency (once per sprite/model teardown, not per-frame). */
+static void mp6_animCacheRemove(ANIMDATA *anim)
+{
+    s16 i;
+    for(i=0; i<MP6_ANIM_CACHE_MAX; i++) {
+        if(mp6_animCache[i].anim == anim || mp6_animCache[i].rawData == (void *)anim) {
+            mp6_animCache[i].rawData = NULL;
+            mp6_animCache[i].anim = NULL;
+        }
+    }
+}
+
+/* MP6 native port -- B2 (docs/B2_BONUS_SPRITE.md). Companion to the
+ * fingerprint check above: that check only catches a stale hit whose
+ * cached CONTENT fingerprint no longer matches what is now at the same
+ * address -- it cannot catch a collision between two objects that
+ * legitimately share the SAME header shape (see that check's own comment).
+ * The real, deterministic fix is not "detect staleness harder", it's
+ * "don't let a stale entry exist across the one event that actually
+ * invalidates a whole batch of them at once": game/objmain.c's
+ * omOvlKill() calls this right after its own `HuMemDirectFreeNum
+ * (HEAP_MODEL, HU_MEMNUM_OVL)` bulk reclaim -- see that call site's own
+ * comment for the full mechanism. A flat wipe (not a range-aware partial
+ * purge) is deliberate: every entry this cache can hold was added by an
+ * HuSprAnimRead/HuSprAnimMake call, and every one of those is reached
+ * (directly or via Hu3DAnimCreate) from game code that runs inside SOME
+ * overlay's own lifetime -- HU_MEMNUM_OVL is, by this engine's own
+ * convention, exactly "freed in bulk when that overlay unloads", so
+ * anything meant to survive past that point would need a different
+ * heap/tag already, independent of this cache. A handful of needless
+ * re-parses of still-valid data on the next overlay's own first frame
+ * (the only cost of over-clearing) is cheap load-time work, not a
+ * per-frame one. */
+void mp6_animCacheClear(void)
+{
+    s16 i;
+    for(i=0; i<MP6_ANIM_CACHE_MAX; i++) {
+        mp6_animCache[i].rawData = NULL;
+        mp6_animCache[i].anim = NULL;
+        mp6_animCache[i].fingerprint = 0;
+    }
+}
