+/* BE fixup + 32-on-64-bit pointer relayout. Two independent problems live
+ * in this one chokepoint:
+ *
+ * 1. Every multi-byte field in the packed ANIM blob (produced by the
+ *    original big-endian PowerPC toolchain) is big-endian; a plain
+ *    struct-member read on this little-endian host reads it byte-swapped.
+ * 2. ANIMDATA/ANIMBANK/ANIMPAT/ANIMBMP each embed one or more real
+ *    pointer-typed fields (bank/pat/bmp, frame, layer, palData/data).
+ *    Those fields are 4 bytes on the original 32-bit target but 8 bytes in
+ *    this native 64-bit build, so the record STRIDES differ from what the
+ *    packed blob actually contains -- walking this data through the
+ *    native struct types in place (as the original code did, relying on
+ *    real hardware's matching 32-bit ABI) reads the wrong bytes entirely,
+ *    a separate bug from pure byte order.
+ *
+ * Fixed by treating `data` as an opaque byte blob laid out per the
+ * ORIGINAL (32-bit, big-endian) ANIM format -- read explicitly via be16()/
+ * be32() at the format's fixed byte offsets -- and building a fresh,
+ * natively-laid-out ANIMDATA/ANIMBANK/ANIMPAT/ANIMBMP/ANIMFRAME/ANIMLAYER
+ * graph from it in one new allocation. ANIMFRAME and ANIMLAYER contain no
+ * pointer fields, so their native layout already matches the packed
+ * layout byte-for-byte; only their s16 fields need swapping. Raw texture/
+ * palette PIXEL bytes (ANIMBMP.data/.palData) are deliberately NOT copied
+ * or byte-swapped -- they stay exactly where the decoder put them and are
+ * consumed as opaque GameCube-native tiled/paletted texture data; only the
+ * CPU-parsed container fields above them are converted here.
+ *
+ * A small side-table cache (mirroring platform/os/dll_bridge.c's own
+ * open-file side table) reproduces the original's "already fixed up, just
+ * bump the refcount" fast path -- the original detected that case by
+ * testing the high bits of the still-packed `bank` OFFSET against a real
+ * pointer's high bits, a test that doesn't transfer once fixed-up data no
+ * longer lives at the same address as its own packed source. */
+/* This cache's budget: 64 was already tight for a full boot's worth of
+ * ANIM objects (79 character anims alone in one loop); the two
+ * self-registration fixes below double the fill rate (each
+ * HuSprAnimRead/HuSprAnimMake call can now add TWO entries, input and
+ * output identity, instead of one). A linear scan over a few thousand
+ * pointer-sized slots costs nothing measurable at this call frequency
+ * (load-time, not per-frame). */
+#define MP6_ANIM_CACHE_MAX 4096
+static struct { void *rawData; ANIMDATA *anim; u32 fingerprint; } mp6_animCache[MP6_ANIM_CACHE_MAX];
+
+/* The cache above assumes a cached entry's key address can only be reused
+ * once HuSprAnimKill has removed it (mp6_animCacheRemove, below) -- true
+ * for per-object teardown, but NOT for the engine's own BULK, tag-based
+ * frees (game/objmain.c / REL/bootDll/boot.c:
+ * `HuMemDirectFreeNum(HEAP_MODEL, HU_MEMNUM_OVL)`, fired wholesale on
+ * every overlay transition). That call reclaims a whole heap region in
+ * one shot without walking individual objects, so it never runs
+ * HuSprAnimKill/mp6_animCacheRemove for anything it frees -- every
+ * mp6_animCache entry keyed by an address inside that region survives,
+ * silently describing memory that no longer holds what it used to. The
+ * next overlay's own loads are free to reuse those same addresses.
+ *
+ * Confirmed concretely: Party Mode loads dozens of same-shaped icon ANIM
+ * files into freshly decompressed buffers, and the Bonus Star icon landed
+ * on an address a stale entry from an earlier overlay's own icon table
+ * still claimed. The cache then returned that stale, unrelated ANIMDATA
+ * (a different pixel format) instead of parsing the fresh bytes -- and
+ * because its own data/palette pointers were computed relative to its own
+ * (also address-reused) raw buffer, they still resolved into the new
+ * resource's real pixel data, just at the old asset's relative offset --
+ * so the port read real index bytes as differently-formatted color pairs
+ * (a smeared image) and then overran past the resource's own pixel data
+ * into whatever followed: exactly a reported "jumble of colored blocks".
+ *
+ * Fix (this check): store a small content FINGERPRINT alongside each cache
+ * entry at add-time (a cheap hash over a couple of STABLE header bytes,
+ * deliberately skipping ANIMDATA's own useNum field, which legitimately
+ * changes across repeat lookups of a genuinely still-valid entry). On a
+ * hit, recompute the SAME fingerprint over what's actually at that address
+ * RIGHT NOW; a mismatch means the bytes underneath changed since this
+ * entry was added -- i.e. the address was reclaimed and reused without
+ * ever going through mp6_animCacheRemove -- so treat it as a MISS instead
+ * of trusting a pointer match against memory that may no longer hold what
+ * it once did.
+ *
+ * NOTE, recorded honestly: this check alone measured as a no-op for the
+ * exact Bonus Star repro, because this game ships many same-sized,
+ * same-shape single-image ANIM icons -- a stale entry from any OTHER
+ * same-shaped icon fingerprints identically to the correct one. Kept as a
+ * second, narrower defense (it does catch a collision against a
+ * differently-shaped stale object); the real fix is mp6_animCacheClear(),
+ * below, called from the one place that actually performs this class of
+ * bulk reclaim. */
+static u32 mp6_animFingerprint(const void *p)
+{
+    const u8 *b = (const u8 *)p;
+    u32 h = 2166136261u;
+    s32 k;
+    for(k = 0; k < 6; k++) {
+        h = (h ^ b[k]) * 16777619u;
+    }
+    for(k = 8; k < 16; k++) {
+        h = (h ^ b[k]) * 16777619u;
+    }
+    return h;
+}
+
+static ANIMDATA *mp6_animCacheFind(void *data)
+{
+    s16 i;
+    for(i=0; i<MP6_ANIM_CACHE_MAX; i++) {
+        if(mp6_animCache[i].rawData == data) {
+            if(mp6_animCache[i].fingerprint == mp6_animFingerprint(data)) {
+                return mp6_animCache[i].anim;
+            }
+            /* Stale: this address no longer holds what was cached (see the
+             * comment above). Drop it and keep looking -- a duplicate,
+             * still-valid entry could exist further along -- rather than
+             * trusting it or giving up early. */
+            mp6_animCache[i].rawData = NULL;
+            mp6_animCache[i].anim = NULL;
+        }
+    }
+    return NULL;
+}
+
+static void mp6_animCacheAdd(void *data, ANIMDATA *anim)
+{
+    s16 i;
+    for(i=0; i<MP6_ANIM_CACHE_MAX; i++) {
+        if(mp6_animCache[i].rawData == NULL) {
+            mp6_animCache[i].rawData = data;
+            mp6_animCache[i].anim = anim;
+            mp6_animCache[i].fingerprint = mp6_animFingerprint(data);
+            return;
+        }
+    }
+    /* Table full: harmless to drop -- a repeat HuSprAnimRead(data) call
+     * just re-parses into its own independent (still correct) copy
+     * instead of sharing/refcounting one. */
+}
+
+/* Real root-cause fix: this table has no expiry, but the ANIMDATA objects
+ * it references DO get freed (HuSprAnimKill, below, once useNum drops to
+ * 0) -- called from here right before the real HuMemDirectFree(anim), so
+ * no stale entry can ever outlive the memory it points at. Purges EVERY
+ * slot whose key OR value matches `anim`: a self-registered entry has
+ * rawData==anim==this exact pointer; an original raw-packed-data-keyed
+ * entry has anim==this pointer but a DIFFERENT rawData key (the still-
+ * packed source blob) -- both need to go, since either one, left stale,
+ * lets a future allocation that happens to reuse this exact freed address
+ * get a false-positive cache hit against unrelated data. A linear scan
+ * over a few thousand slots costs nothing measurable at this call
+ * frequency (once per sprite/model teardown, not per-frame). */
+static void mp6_animCacheRemove(ANIMDATA *anim)
+{
+    s16 i;
+    for(i=0; i<MP6_ANIM_CACHE_MAX; i++) {
+        if(mp6_animCache[i].anim == anim || mp6_animCache[i].rawData == (void *)anim) {
+            mp6_animCache[i].rawData = NULL;
+            mp6_animCache[i].anim = NULL;
+        }
+    }
+}
+
+/* Companion to the fingerprint check above: that check only catches a
+ * stale hit whose cached CONTENT fingerprint no longer matches what is
+ * now at the same address -- it cannot catch a collision between two
+ * objects that legitimately share the SAME header shape. The real,
+ * deterministic fix is not "detect staleness harder", it's "don't let a
+ * stale entry exist across the one event that actually invalidates a
+ * whole batch of them at once": game/objmain.c's omOvlKill() calls this
+ * right after its own bulk HEAP_MODEL/HU_MEMNUM_OVL reclaim -- see that
+ * call site's own comment for the full mechanism. A flat wipe (not a
+ * range-aware partial purge) is deliberate: every entry this cache can
+ * hold is reached from game code that runs inside some overlay's own
+ * lifetime, and HU_MEMNUM_OVL is, by this engine's own convention, exactly
+ * "freed in bulk when that overlay unloads" -- anything meant to survive
+ * past that point would need a different heap/tag already, independent of
+ * this cache. A handful of needless re-parses of still-valid data on the
+ * next overlay's own first frame is cheap load-time work, not a per-frame
+ * one. */
+void mp6_animCacheClear(void)
+{
+    s16 i;
+    for(i=0; i<MP6_ANIM_CACHE_MAX; i++) {
+        mp6_animCache[i].rawData = NULL;
+        mp6_animCache[i].anim = NULL;
+        mp6_animCache[i].fingerprint = 0;
+    }
+}
