--- a/src/game/init.c
+++ b/src/game/init.c
@@ -7,0 +8 @@
+#include "mp6_widescreen.h" /* widescreen support */
@@ -43,0 +45,48 @@
+/* The render-target-widening crux: this is what makes the game's GX
+ * render target genuinely wider than 640 (not a post-hoc stretch of a
+ * 640-wide image) when widescreen is on, generalizing what the reference
+ * widescreen hack's injected boot-time code most likely does to the live
+ * RenderMode struct to an arbitrary, live-window-derived width instead of
+ * a hardcoded fixed one.
+ *
+ * RenderMode->fbWidth is a plain runtime struct field several call sites
+ * already read dynamically (Hu3DCameraCreate's viewportW/scissorW,
+ * hsfman.c; InitGX's own GXSetViewport/GXSetScissor a few lines below
+ * this function) -- overwriting it here and re-running VIConfigure() is
+ * enough to widen every one of those "for free", with no further decomp
+ * edit needed at those sites at all. VIConfigure() matters because
+ * Aurora's own GX emulation derives its "logical" framebuffer size from
+ * whatever GXRenderModeObj was last handed to VIConfigure, not from
+ * RenderMode itself -- so the pointer write alone isn't enough; this
+ * function's whole reason to exist is doing both together, atomically,
+ * from one call.
+ *
+ * A true no-op (early-returns) when newFbWidth already equals
+ * RenderMode->fbWidth, so calling this every tick (platform/gx/
+ * aurora_bridge.c's VIWaitForRetrace does, to track a live interactive
+ * resize) is cheap, and it is a provable no-op in the --headless build
+ * (mp6_widescreen_render_width() always returns 640 there, already
+ * matching GXNtsc480IntDf's compiled-in fbWidth). Guarded by a RUNTIME
+ * flag throughout (mp6_widescreen_render_width() itself returns the
+ * native 640 unless widescreen is actually on), never a compile-time
+ * #ifdef -- this function and its one call site below compile into every
+ * build, and are a byte-for-byte no-op whenever widescreen is off (the
+ * default). */
+void mp6_widescreen_apply_render_width(int newFbWidth)
+{
+    static GXRenderModeObj mp6WideRenderMode;
+    if (RenderMode == NULL || newFbWidth <= 0 || (u32)newFbWidth == (u32)RenderMode->fbWidth) {
+        return;
+    }
+    mp6WideRenderMode = *RenderMode;
+    mp6WideRenderMode.fbWidth = (u16)newFbWidth;
+    /* efbHeight/xfbHeight deliberately untouched -- height never changes,
+     * per spec; only the width widens. */
+    RenderMode = &mp6WideRenderMode;
+    VIConfigure(RenderMode);
+}
+
@@ -54,0 +104,8 @@
+    /* Establishes the wide RenderMode as early as physically possible --
+     * before InitGX() (a few lines below) ever reads RenderMode->fbWidth
+     * for the boot-time GXSetViewport/GXSetScissor calls -- so there is no
+     * even-one-frame native-4:3 transient on a widescreen boot. The
+     * per-tick refresh (aurora_bridge.c's VIWaitForRetrace) covers every
+     * frame after this one, including a live interactive resize. */
+    mp6_widescreen_apply_render_width(mp6_widescreen_render_width());
