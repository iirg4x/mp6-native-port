-    MTXOrtho(proj, 0, HU_DISP_HEIGHT, 0, HU_DISP_WIDTH, 0, 10);
+    /* This is THE per-frame (called from hsfman.c's Hu3DExec every frame,
+     * and from this file's own mode-transition points) entry point that
+     * (re)establishes the 2D/HUD orthographic projection + viewport +
+     * scissor -- i.e. the entire 2D "canvas" every window/sprite-group
+     * draw goes through. Widening only the RIGHT edge left-anchors all 2D
+     * content -- an element at logical x=0 stays pinned to the true left
+     * edge while the extra width opens up only on the right, so anything
+     * not touched by a per-element shim stayed exactly where it was, and
+     * anything touched twice (a window whose position AND whose forwarded
+     * sprite-group position both got shifted) moved twice as far as
+     * intended -- the exact mispositioned-tag / cut-off-text symptom
+     * reported against file-select and the opening storybook. Recentering
+     * here instead -- shifting the LEFT edge out by the same
+     * half_width_delta the old per-element shims used to add -- maps the
+     * original [0, HU_DISP_WIDTH] logical range onto the CENTER of the
+     * wider canvas: the total span is unchanged, so every 2D element, with
+     * NO per-element shim at all, translates by exactly the same pixel
+     * delta as every other one, preserving each screen's own relative
+     * layout instead of depending on each element flowing through exactly
+     * one shimmed setter. No-op (byte-identical native calls) when
+     * disabled. */
+    MTXOrtho(proj, 0, HU_DISP_HEIGHT, -mp6_widescreen_half_width_delta(), HU_DISP_WIDTH + mp6_widescreen_half_width_delta(), 0, 10);
