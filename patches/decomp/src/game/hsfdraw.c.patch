+/* MP6 native port -- M11 : object-level draw
+ * census, the per-OBJECT companion to hsfman.c's per-MODEL one (that
+ * patch's MP6_DRAW_CENSUS explains what the Hu3DExec loop decided; this
+ * one, behind its own MP6_DRAW_CENSUS_OBJ=<tick>, explains what happened
+ * INSIDE each Hu3DDraw tree walk: which objects were visited, which were
+ * skipped by LOCK/DISPOFF-flags/zero-scale, which deferred to the
+ * z-sorted XLU list, and which reached ObjDraw). Same two-tick window
+ * semantics as the hsfman census; zero output and one cached getenv when
+ * unset. PORT-DIAGNOSTIC ONLY: prints state, never changes behavior. */
+#include <stdio.h>
+#include <stdlib.h>
+extern long mp6_tick_count;
+static long mp6ObjCensusTick = -2; /* -2 = env not parsed yet, -1 = disabled */
+static int mp6ObjCensusActive(void)
+{
+    if (mp6ObjCensusTick == -2) {
+        const char *e = getenv("MP6_DRAW_CENSUS_OBJ");
+        mp6ObjCensusTick = (e && atol(e) > 0) ? atol(e) : -1;
+    }
+    return mp6ObjCensusTick > 0 && mp6_tick_count >= mp6ObjCensusTick &&
+           mp6_tick_count < mp6ObjCensusTick + 2;
+}
+
+/* MP6 native port -- M13 : display-list /
+ * vertex ground-truth dump. The mode-select/file-select "vertices all over
+ * the place" hunt needs the actual bytes, not more theories: for the one
+ * object named by MP6_DL_DUMP=<name> this dumps, at DL-BUILD time
+ * (MDObjMesh, i.e. model-create), to build/dldump_<name>.txt:
+ *   - the parsed face records (type/mat/index tuples) the DL was built from,
+ *   - the vertex/st array contents summary (count, first entries, min/max
+ *     magnitude, out-of-range-index scan over every face tuple),
+ *   - the referenced materials' vtxMode/attrNum/flags (the vertex-descriptor
+ *     selectors), and
+ *   - the raw built DL bytes (first 1 KB hex) + per-batch dlOfs table.
+ * Decoding those bytes against the descriptor the draw path will set is a
+ * mechanical, offline check of stream-vs-descriptor alignment. One getenv,
+ * zero output when unset. PORT-DIAGNOSTIC ONLY: never changes behavior. */
+#include <string.h>
+static int mp6DlDumpParsed = 0;       /* 0 = env not parsed yet */
+static const char *mp6DlDumpName = NULL;
+static const char *mp6DlDumpEnv(void)
+{
+    if (!mp6DlDumpParsed) {
+        mp6DlDumpName = getenv("MP6_DL_DUMP");
+        mp6DlDumpParsed = 1;
+    }
+    return mp6DlDumpName;
+}
+static int mp6DlDumpWant(const char *objName)
+{
+    const char *want = mp6DlDumpEnv();
+    return want && objName && strcmp(want, objName) == 0;
+}
