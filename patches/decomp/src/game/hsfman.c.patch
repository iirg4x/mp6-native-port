+/* MP6 native port -- On real hardware this lookup
+ * always finds a real object -- a model's real HSF data always has the
+ * name callers ask for, so returning NULL here was pure defensive code,
+ * never actually exercised. The M2c HSF stub (a
+ * frontier, deferred rather than solved) gives every model an EMPTY
+ * object list on purpose, so this lookup now genuinely fails every time
+ * -- and 18 call sites across 7 files (src/REL/bootDll/opening.c alone
+ * has 6, src/REL/fileseldll/filesel.c has 2 -- grep-confirmed, not
+ * guessed) immediately write through the result with no NULL check of
+ * their own (object->mesh.base.pos.x = ..., the same shape this patch
+ * queue already fixed once for Hu3DAnimAnimSet/HuAR_ARAMtoMRAMFileRead's
+ * own callers). Patching all 18 call sites individually -- several in
+ * files this milestone hasn't even reached yet -- is far more surface
+ * area than fixing the one shared chokepoint they all already funnel
+ * through. This dummy is a plain zeroed HSF_OBJECT, never linked into
+ * any real hsf->root/object[] tree, so nothing ever traverses INTO it
+ * (Hu3DDraw/MakeDisplayList never see it); it only ever absorbs a
+ * caller's writes harmlessly instead of crashing. Shared across every
+ * "not found" case rather than allocated fresh: nothing ever reads a
+ * meaningful value back out of it, so there is no cross-talk to avoid. */
+static HSF_OBJECT mp6_dummyObj;
+
 HSF_OBJECT *Hu3DModelObjPtrGet(HU3D_MODELID modelId, char *objName)
 {
     char name[HSF_OBJNAME_MAX_LEN];
@@ -949,7 +1060,7 @@
     if(i == hsf->objectNum) {
         OSReport("Error: OBJPtr Error! %s\n", objName);
     }
-    return NULL;
+    return &mp6_dummyObj;
 }
 
