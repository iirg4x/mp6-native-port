+/* MP6 native port -- M11 (docs/M11_WORDMARK_STAR.md): the title-wordmark
+ * draw census. M10's framescope census proved the three BootTitleCreate
+ * models (TITLE_HSF_PARTY/SIX/STAR) never load a single texture on the
+ * title frame -- i.e. they never reach ObjDraw at all -- but framescope
+ * can only see GX calls, not WHY the Hu3DExec model loop skipped a model.
+ * This census prints, for MP6_DRAW_CENSUS=<tick> (two consecutive ticks
+ * starting there, so one full Hu3DExec pass is guaranteed even if the
+ * first armed tick lands mid-frame):
+ *   - one entry-state dump per Hu3DExec call (live cameras, layerNum[],
+ *     and every live model's routing state: layer, cameraBit, attr bits,
+ *     scale, motion id, object count), and
+ *   - one verdict line per live model on its OWN layer's pass per camera,
+ *     evaluating the loop's real skip chain in the loop's real order.
+ * Zero output and one getenv (cached) when the env var is unset.
+ * PORT-DIAGNOSTIC ONLY: prints state, never changes behavior. */
+extern long mp6_tick_count;
+static long mp6CensusTick = -2; /* -2 = env not parsed yet, -1 = disabled */
+static int mp6CensusActive(void)
+{
+    if (mp6CensusTick == -2) {
+        const char *e = getenv("MP6_DRAW_CENSUS");
+        mp6CensusTick = (e && atol(e) > 0) ? atol(e) : -1;
+    }
+    return mp6CensusTick > 0 && mp6_tick_count >= mp6CensusTick &&
+           mp6_tick_count < mp6CensusTick + 2;
+}
