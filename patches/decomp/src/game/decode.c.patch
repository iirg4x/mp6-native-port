+/* MP6 native port -- M13 : decode guard.
+ * The menu-scene "vertices all over the place" hunt traced corrupt HSF face
+ * indices to the DECODED DATA BLOB (bad already at parse time, float-flavored
+ * garbage, nondeterministic between runs). This choke point logs, for
+ * MP6_DECODE_GUARD=1, every decompression: type, dst range, expected size,
+ * BYTES ACTUALLY WRITTEN (an overrun writes into neighboring heap blocks --
+ * the prime stomp suspect), leftover size counter (u32 underflow detector),
+ * and a djb2 checksum of the output (two runs diff run-to-run
+ * nondeterminism per decode). Zero output and one cached getenv when unset.
+ * PORT-DIAGNOSTIC ONLY: prints state, never changes behavior. */
+static int mp6DecodeGuardFlag = -1;
+static int mp6DecodeGuardOn(void)
+{
+    if (mp6DecodeGuardFlag < 0) {
+        const char *e = getenv("MP6_DECODE_GUARD");
+        mp6DecodeGuardFlag = (e != NULL && e[0] != '\0' && e[0] != '0') ? 1 : 0;
+    }
+    return mp6DecodeGuardFlag;
+}
+
 void HuDecodeData(void *src, void *dst, u32 size, s32 decodeType)
 {
     DECODE decode;
@@ -211,6 +234,21 @@ void HuDecodeData(void *src, void *dst, u32 size, s32 decodeType)
             OSReport("decode tyep unknown.(%x)\n", decodeType);
