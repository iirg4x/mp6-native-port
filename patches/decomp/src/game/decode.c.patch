+/* Decode guard. The menu-scene "vertices all over the place" hunt traced
+ * corrupt HSF face indices to the DECODED DATA BLOB (bad already at parse
+ * time, float-flavored garbage, nondeterministic between runs). This
+ * choke point logs, for MP6_DECODE_GUARD=1, every decompression: type,
+ * dst range, expected size, BYTES ACTUALLY WRITTEN (an overrun writes
+ * into neighboring heap blocks -- the prime stomp suspect), leftover size
+ * counter (u32 underflow detector), and a djb2 checksum of the output
+ * (two runs diff run-to-run nondeterminism per decode). Zero output and
+ * one cached getenv when unset. Diagnostic only: prints state, never
+ * changes behavior. */
+static int mp6DecodeGuardFlag = -1;
+static int mp6DecodeGuardOn(void)
+{
+    if (mp6DecodeGuardFlag < 0) {
+        const char *e = getenv("MP6_DECODE_GUARD");
+        mp6DecodeGuardFlag = (e != NULL && e[0] != '\0' && e[0] != '0') ? 1 : 0;
+    }
+    return mp6DecodeGuardFlag;
+}
+
@@ -213,0 +237,15 @@
+    if (mp6DecodeGuardOn()) { /* decode guard -- see mp6DecodeGuardOn above */
+        unsigned char *d0 = (unsigned char *)dst;
+        long long wrote = (long long)(decodeP->dst - d0); /* dst-advancing decoders only */
+        unsigned int sum = 5381u;
+        u32 k;
+        int lenCheckValid = (decodeType != HU_DECODE_TYPE_ZLIB); /* zlib path doesn't advance decodeP->dst */
+        for (k = 0; k < size; k++) {
+            sum = sum * 33u + d0[k];
+        }
+        printf("[DECODE] type=%d dst=%p..%p size=%u wrote=%lld left=%u sum=%08x%s\n",
+               (int)decodeType, dst, (void *)(d0 + size), (unsigned)size,
+               wrote, (unsigned)decodeP->size, sum,
+               (lenCheckValid && wrote != (long long)size) ? "  <-- LENGTH MISMATCH (overrun/underrun)" : "");
+        fflush(stdout);
+    }
@@ -236 +274 @@
-    stream.avail_in = src[1];
+    stream.avail_in = be32(&src[1]);
@@ -240 +278 @@
-    stream.avail_out = (uInt)(&dummy);
