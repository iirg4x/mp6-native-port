+/* MP6 native port -- M13 (docs/M13_MENUS_TO_REFERENCE.md): the om-object
+ * execution census. M11 proved (docs/M11_WORDMARK_STAR.md section 3,
+ * [CENSUS-CAM]) that at least one om object (bootDll's OutViewObj) is
+ * CREATED but never EXECUTED on the full-story path, and M13's two broken
+ * screens (mode select: nearly all plaza models absent + camera low; file
+ * select: black backdrop masses) both belong to overlays whose scene
+ * models are created INSIDE om objFuncs (one-shot mode-0 creators like
+ * mdsel fn_1_6F40). This census makes omMain's walk auditable:
+ *   MP6_OM_CENSUS=1 logs
+ *   - omInitObjMan (capacity, overlay),
+ *   - every omAddObjEx/omDelObjEx (slot, prio, counts, symbolized func),
+ *   - every stat-bit transition through omSetStatBit/omResetStatBit with
+ *     the SYMBOLIZED CALLER (who paused/disabled what),
+ *   - per-object walk verdicts (RUN / FUNC_NULL / GATED(0x40|8|PAUSED) /
+ *     DELETED|DISABLED-in-list) logged ON CHANGE only,
+ *   - a per-pass summary line when the (ran/funcnull/gated/disabled)
+ *     tuple changes, plus a heartbeat every 600 passes (positive evidence
+ *     omMain is still being dispatched at all),
+ *   - transitions of the HuLoadProcModeGet() whole-walk gate.
+ * Diffing ADD lines against RUN lines answers created-vs-executed
+ * directly. Zero output and one cached getenv when the env var is unset.
+ * PORT-DIAGNOSTIC ONLY: prints state, never changes behavior. */
+extern long mp6_tick_count;                      /* platform main loop tick */
+void mp6_symbolize_addr(void *addr, char *outBuf, size_t outBufSz); /* crash_handler.c (M8) */
+
+#define MP6_OMC_MAX 512
+#define MP6_OMC_UNSEEN 0
+#define MP6_OMC_RUN 1
+#define MP6_OMC_FUNCNULL 2
+#define MP6_OMC_GATED 3
+#define MP6_OMC_DEADLISTED 4
+static int mp6OmCensusFlag = -1; /* -1 = env not parsed yet */
+static unsigned char mp6OmcVerdict[MP6_OMC_MAX];
+static unsigned short mp6OmcStat[MP6_OMC_MAX];
+static int mp6OmcLoadGateOn;
+static int mp6OmcRan, mp6OmcFuncNull, mp6OmcGated, mp6OmcDead;
+static long mp6OmcPassNo;
+static long long mp6OmcLastKey = -1; /* 64-bit: the pass key packs ovl above bit 32 */
+
+static int mp6OmCensusOn(void)
+{
+    if (mp6OmCensusFlag < 0) {
+        const char *e = getenv("MP6_OM_CENSUS");
+        mp6OmCensusFlag = (e != NULL && e[0] != '\0' && e[0] != '0') ? 1 : 0;
+    }
+    return mp6OmCensusFlag;
+}
+
+static void mp6OmcSym(void *fn, char *buf, size_t bufSz)
+{
+    buf[0] = '\0';
+    if (fn == NULL) {
+        snprintf(buf, bufSz, "(null)");
+        return;
+    }
+    mp6_symbolize_addr(fn, buf, bufSz);
+    if (buf[0] == '\0') {
+        snprintf(buf, bufSz, "%p", fn);
+    }
+}
+
+static const char *mp6OmcVerdictName(int verdict)
+{
+    switch (verdict) {
+        case MP6_OMC_RUN: return "RUN";
+        case MP6_OMC_FUNCNULL: return "FUNC_NULL";
+        case MP6_OMC_GATED: return "GATED";
+        case MP6_OMC_DEADLISTED: return "DEAD_IN_LIST";
+        default: return "UNSEEN";
+    }
+}
+
+/* Log a walk verdict for one object, only when the verdict OR the raw stat
+ * word changed since the last time this slot was walked. */
+static void mp6OmcNote(OMOBJ *obj, int verdict)
+{
+    int slot = obj->objNext;
+    if (slot < 0 || slot >= MP6_OMC_MAX) {
+        return;
+    }
+    if (mp6OmcVerdict[slot] != (unsigned char)verdict || mp6OmcStat[slot] != obj->stat) {
+        char sym[256];
+        mp6OmcSym((void *)obj->objFunc, sym, sizeof(sym));
+        printf("[OM-CENSUS] tick=%ld ovl=%d obj=%d prio=%04x stat=%04x func=%s verdict=%s (was %s)\n",
+               mp6_tick_count, (int)omcurovl, slot, (unsigned)(u16)obj->prio,
+               (unsigned)obj->stat, sym, mp6OmcVerdictName(verdict),
+               mp6OmcVerdictName(mp6OmcVerdict[slot]));
+        mp6OmcVerdict[slot] = (unsigned char)verdict;
+        mp6OmcStat[slot] = obj->stat;
+    }
+}
+
