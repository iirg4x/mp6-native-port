 void omSetStatBit(OMOBJ *obj, u16 bit)
 {
+    if (mp6OmCensusOn() && (u16)(obj->stat | bit) != obj->stat) {
+        /* M13 om census -- who set which gate bit on which object */
+        char sym[256];
+        mp6OmcSym(__builtin_return_address(0), sym, sizeof(sym));
+        printf("[OM-CENSUS] tick=%ld ovl=%d STAT+ obj=%d %04x->%04x (+%04x) by %s\n",
+               mp6_tick_count, (int)omcurovl, (int)obj->objNext, (unsigned)obj->stat,
+               (unsigned)(u16)(obj->stat | bit), (unsigned)bit, sym);
+    }
     obj->stat |= bit;
 }
 
 void omResetStatBit(OMOBJ *obj, u16 bit)
 {
+    if (mp6OmCensusOn() && (u16)(obj->stat & ~bit) != obj->stat) {
+        /* M13 om census -- who cleared which gate bit on which object */
+        char sym[256];
+        mp6OmcSym(__builtin_return_address(0), sym, sizeof(sym));
+        printf("[OM-CENSUS] tick=%ld ovl=%d STAT- obj=%d %04x->%04x (-%04x) by %s\n",
+               mp6_tick_count, (int)omcurovl, (int)obj->objNext, (unsigned)obj->stat,
+               (unsigned)(u16)(obj->stat & ~bit), (unsigned)bit, sym);
+    }
     obj->stat &= ~bit;
 }
 
