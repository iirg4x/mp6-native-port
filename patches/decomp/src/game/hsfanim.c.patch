+/* Texture-anim frame/region census, gated by the same MP6_DRAW_CENSUS_OBJ
+ * env var and tick window as hsfdraw.c's own object census. One line per
+ * Hu3DAnimSet evaluation: which anim slot picked which pattern/bitmap and
+ * the sheet sub-region (layer start/size vs bitmap dims -> the texture
+ * matrix scale/translate hsfdraw will apply). Diagnostic only: prints
+ * state, never changes behavior. */
+#include <stdio.h>
+#include <stdlib.h>
+extern long mp6_tick_count;
+static long mp6AnimCensusTick = -2; /* -2 = env not parsed yet, -1 = disabled */
+static int mp6AnimCensusActive(void)
+{
+    if (mp6AnimCensusTick == -2) {
+        const char *e = getenv("MP6_DRAW_CENSUS_OBJ");
+        mp6AnimCensusTick = (e && atol(e) > 0) ? atol(e) : -1;
+    }
+    return mp6AnimCensusTick > 0 && mp6_tick_count >= mp6AnimCensusTick &&
+           mp6_tick_count < mp6AnimCensusTick + 2;
+}
