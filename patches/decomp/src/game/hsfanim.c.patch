+/* MP6 native port -- P1 : register the three
+ * arrays particleFunc binds with GXSetArray right before its
+ * GXCallDisplayList replay, so the port's bridge (platform/gx/
+ * aurora_bridge.c mp6_GXSetArray3) takes the authoritative registry path
+ * (real byte size -> Aurora uploads the whole array for the DL's indexed
+ * fetches) instead of the learned-size fallback (0 for these: no
+ * immediate-mode GXBegin ever follows these binds; the DL was recorded
+ * once in Hu3DParticleCreate). The exact upload windows the recorded DL
+ * needs, matching particleFunc's own binds:
+ *   GX_VA_POS  vtxBuf, stride sizeof(HuVecF), indices 0..maxCnt*4-1
+ *              -> maxCnt*4*sizeof(HuVecF) bytes (the whole allocation);
+ *   GX_VA_CLR0 &data->color, stride sizeof(HU3D_PARTICLE_DATA), indices
+ *              0..maxCnt-1 -> (maxCnt-1)*stride + sizeof(GXColor) bytes
+ *              (never past data[]'s allocation end: color is a member of
+ *              the last element, so this is exactly the allocation's tail
+ *              from that pointer -- Aurora reads the registered window
+ *              from CPU memory on every bind);
+ *   GX_VA_TEX0 baseST (this file's own static above), 4 entries.
+ * mp6_gxarray_register is compiled into BOTH build modes (see
+ * platform/gx/gxarray_registry.c) and re-registering a reused heap
+ * address just updates the entry in place, so a killed-and-recreated
+ * particle model stays correct. Registered at create time (not per draw)
+ * to mirror hsf_load_native.c's own register-at-load convention. */
+#include "mp6_gxarray_registry.h"
+static void mp6ParticleArraysRegister(HU3D_PARTICLE *particleP)
+{
+    if (particleP->maxCnt <= 0) {
+        return; /* no drawable quads; (maxCnt-1) below would underflow */
+    }
+    mp6_gxarray_register(particleP->vtxBuf,
+                         (uint32_t)particleP->maxCnt * 4u * (uint32_t)sizeof(HuVecF));
+    mp6_gxarray_register(&particleP->data->color,
+                         ((uint32_t)particleP->maxCnt - 1u) * (uint32_t)sizeof(HU3D_PARTICLE_DATA)
+                             + (uint32_t)sizeof(GXColor));
+    mp6_gxarray_register(baseST, (uint32_t)sizeof(baseST));
+}
+
 static void particleFunc(HU3D_MODEL *modelP, Mtx *mtx)
 {
     HuVecF *vtxBuf;
