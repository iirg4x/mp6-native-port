+/* MP6 native port -- . messDataPtr (game/window.c's
+ * HuWinMesRead()) is a plain memcpy() of a real DVD file's raw bytes
+ * (mess/messdata*.bin), never byte-swapped on the way in -- the exact
+ * same "directory count, then a per-entry offset table" container shape
+ * game/data.c's GetFileInfo and game/armem.c's HuAR_ARAMtoMRAMFileRead
+ * already fix elsewhere in this patch queue, just unfixed here until now.
+ * Every one of these 3 functions read it as plain native u32 -- wrong on
+ * every single call, not just an edge case, which is exactly why "Error:
+ * Message Dir Over"/"Error: Message Number Over" fired on EVERY message
+ * lookup this port ever made (confirmed: neither original error path
+ * actually returns early, so a garbage bounds check silently let a
+ * garbage offset chain through every time). OpeningExec's own
+ * HuWinMesSet(messageWinId, 0x10005) call is what surfaced this: the
+ * corrupted messData pointer it produced is the direct cause of the
+ * first-ever "GXBegin: called without matching GXEnd" Aurora FATAL this
+ * port hit, a few lines later, once real frame drawing tried to use it. */
+u32 HuWinMesMaxDirGet(void)
+{
+    u32 *dirNum = messDataPtr;
+    return be32(dirNum);
+}
+
+u32 HuWinMesMaxNumGet(u32 dirNum)
+{
+    u32 dir = dirNum >> 16;
+    u32 *messData = messDataPtr;
+    if(dir >= be32(messData)) {
+        OSReport("Error: Message Dir Over\n");
+    }
+    messData++;
+    messData += be32(&messData[dir])/sizeof(u32);
+    return be32(messData);
+}
+
+void *HuWinMesDataPtrGet(void *data, u32 messNum)
+{
+    u32 dir = messNum >> 16;
+    u32 num = messNum & 0xFFFF;
+    u32 *messData = data;
+    if(dir >= be32(messData)) {
+        OSReport("Error: Message Dir Over\n");
+    }
+    messData++;
+    messData += be32(&messData[dir])/sizeof(u32);
+    if(num >= be32(messData)) {
+        OSReport("Error: Message Number Over\n");
+    }
+    messData++;
+    messData += be32(&messData[num])/sizeof(u32);
+    messData++;
+    return messData;
+}
