--- a/src/game/data.c
+++ b/src/game/data.c
@@ -3,0 +4 @@
+#include "be.h"
@@ -330,0 +332,3 @@
+    /* dirP's own directory/index table and the per-file rawLen/decodeType
+     * header are both big-endian-packed -- read via be32() rather than a
+     * native u32 dereference. */
@@ -333 +337 @@
-    readStat->fileDataP = PTR_OFFSET(readStat->dirP, *ptr);
+    readStat->fileDataP = PTR_OFFSET(readStat->dirP, be32(ptr));
@@ -335,2 +339,2 @@
-    readStat->rawLen = *ptr++;
-    readStat->decodeType = *ptr++;
+    readStat->rawLen = be32(ptr); ptr++;
+    readStat->decodeType = be32(ptr); ptr++;
@@ -670,0 +675,2 @@
+		/* Aligned case: same big-endian header as the unaligned branch above,
+		 * just read a word at a time -- needs the same be32() fix. */
@@ -672,2 +678,2 @@
-		rawLen = *data++;
-		decodeType = *data++;
+		rawLen = (s32)be32(data); data++;
+		decodeType = (s32)be32(data); data++;
