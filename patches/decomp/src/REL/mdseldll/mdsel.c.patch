+/* Matches every decoration sub-object that must REPOSITION (never resize)
+ * alongside "sora"'s own widening -- all 6 "cloud*" and 7 "star*" objects
+ * (name-prefix match; confirmed against the model's full per-object
+ * census that no other names share either prefix). Split into two
+ * predicates (clouds vs. stars) so the call site can bias each
+ * independently: an on-device report found day-side clouds still sitting
+ * too far right of the stretched checkered split, not spread evenly
+ * across the widened day region, while the night-side stars looked
+ * correct -- one shared predicate could only apply one amount to both. */
+static int mp6_mdsel_sky_is_cloud(const char *name)
+{
+    return strncmp(name, "cloud", 5) == 0;
+}
+
+static int mp6_mdsel_sky_is_star(const char *name)
+{
+    return strncmp(name, "star", 4) == 0;
+}
