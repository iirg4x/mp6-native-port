--- a/src/REL/sequencedll/sequence.c
+++ b/src/REL/sequencedll/sequence.c
@@ -10,0 +11 @@
+#include "mp6_widescreen.h" /* widescreen support */
@@ -80,2 +81,10 @@
-    Hu3DCameraPerspectiveSet(HU3D_CAM0, 45, 20, 10000, 1.2f);
-    Hu3DCameraViewportSet(HU3D_CAM0, 0, 0, 640, 480, 0, 1);
+    /* This overlay's own 3D camera has the same native-640, left-anchored
+     * framing as the other overlay screens, left native to match the
+     * reference widescreen hack's own scope, leaving a black band on the
+     * right. Widened the same way as hsfman.c's defCamera/opening.c's
+     * camera: FOV aspect x scale_factor(), viewport width -> live render
+     * width. No-op when widescreen is disabled. */
+    Hu3DCameraPerspectiveSet(HU3D_CAM0, 45, 20, 10000, 1.2f * mp6_widescreen_scale_factor());
+    Hu3DCameraViewportSet(HU3D_CAM0, 0, 0, mp6_widescreen_render_width(), 480, 0, 1);
