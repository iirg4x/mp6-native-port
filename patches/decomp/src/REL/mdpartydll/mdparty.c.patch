+        mp6_widescreen_floor_border_fill_dup_kill_all();
@@ -2011,0 +2296,42 @@
+        /* The golden swirl-ring backdrop ("CP") used to get the same
+         * whole-model isotropic extrude as the pillar/floor above, but that
+         * scale also magnifies -- and visibly softens -- the native center
+         * art (confirmed against a native 4:3 crop). Replaced by a
+         * pinned-UV rim ring instead: the disc itself stays native
+         * (undistorted center detail), and mp6_widescreen_extend_ring()
+         * appends one quad per rim chord (16) into the disc's own buffers
+         * -- inner loop = the native rim vertices verbatim (watertight),
+         * outer loop = the same positions scaled outward by k -- both
+         * carrying each chord's own rim UVs, so the ring reads as more of
+         * the same flat opaque gold band the disc's own edge already
+         * samples (a radial mirror would replay the disc's transparent
+         * interior as a see-through moat; a flat-color surround would carry
+         * a visible RGB step -- both rejected on the measured pixel data).
+         *
+         * Registered once, at i==0 -- deliberately BEFORE the i==1
+         * Hu3DModelLink duplicate below runs: registration grows the disc's
+         * buffers and re-bakes its display lists, and Hu3DObjDuplicate
+         * (game/hsfdraw.c, inside Hu3DModelLink) memcpy's the object array
+         * plus each constData, so the twin created AFTER the re-bake shares
+         * the grown bake and buffers outright -- both instances ride the
+         * one per-tick ring rewrite. Two accepted side effects: the
+         * authored gold surround becomes visible in the wide corners
+         * (matching the native 4:3 frame's own composition, which already
+         * just grazes the gold band there), and the live board-map render
+         * targets parented to this same model no longer scale with the
+         * window -- foreground content stays native size, where the old
+         * whole-model extrude grew it with the backdrop. */
+        if (i == 0) {
+            mp6_widescreen_extend_ring(obj->mdlId[i], "CP");
+        }
